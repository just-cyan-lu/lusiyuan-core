{
  "name": "lusiyuan-core",
  "version": "0.1.0",
  "description": "陆思源 AI 数字人 Core API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "smoke": "tsx scripts/smoke-test.ts",
    "seed:admin": "tsx scripts/seed-admin-demo.ts",
    "web:dev": "cd web && pnpm dev",
    "web:build": "cd web && pnpm build",
    "web:install": "cd web && pnpm install",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "telegram:dev": "tsx watch scripts/start-telegram.ts",
    "telegram:dev:deprecated": "echo 'DEPRECATED: Use pnpm dev with TELEGRAM_ENABLED=true instead' && exit 1",
    "embeddings:backfill": "tsx scripts/backfill-memory-embeddings.ts",
    "embeddings:inspect": "tsx scripts/inspect-memory-retrieval.ts",
    "tools:inspect": "tsx scripts/inspect-tools.ts",
    "reflection:run": "tsx scripts/run-reflection.ts",
    "reflection:inspect": "tsx scripts/inspect-reflection-report.ts",
    "reflection:apply": "tsx scripts/apply-memory-proposals.ts",
    "dream:run": "tsx scripts/run-dream.ts",
    "dream:inspect": "tsx scripts/inspect-dream-job.ts",
    "dream:diary": "tsx scripts/inspect-dream-diary.ts",
    "dream:cleanup-locks": "tsx scripts/cleanup-dream-locks.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.0.2",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.2",
    "grammy": "^1.43.0",
    "https-proxy-agent": "^9.0.0",
    "node-cron": "^3.0.3",
    "openai": "^4.103.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.52.0",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
