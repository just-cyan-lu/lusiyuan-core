DATABASE_URL="postgresql://lusiyuan:password@localhost:5432/lusiyuan_core"
PORT=64100

MODEL_PROVIDER="openai-compatible"
MODEL_BASE_URL="https://api.openai.com/v1"
MODEL_API_KEY="your-api-key"
MODEL_NAME="gpt-4.1-mini"

MEMORY_EXTRACTION_MODEL_NAME="gpt-4.1-mini"

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=""
TELEGRAM_MODE="polling"
TELEGRAM_PROXY=""

# Weixin (via OpenClaw bridge)
WEIXIN_ENABLED=false
WEIXIN_BRIDGE_SECRET=""

# Web
WEB_ORIGIN="http://localhost:64111"

# Security
OWNER_USER_IDS="telegram:123456"
MAX_MESSAGE_LENGTH=4000

# Embedding (SiliconFlow Qwen/Qwen3-Embedding-4B)
EMBEDDING_BASE_URL="https://api.siliconflow.cn/v1"
EMBEDDING_API_KEY=""
EMBEDDING_MODEL="Qwen/Qwen3-Embedding-4B"
EMBEDDING_DIMENSIONS=1024

# Memory retrieval (v0.4)
MEMORY_RETRIEVAL_ENABLED=false
MEMORY_SEMANTIC_TOP_K=30
MEMORY_FINAL_TOP_K=8
MEMORY_MAX_TOTAL_CHARS=1200
MEMORY_VECTOR_INDEX_PROVIDER="pgvector"
