DATABASE_URL="postgresql://lusiyuan:password@localhost:5432/lusiyuan_core"
PORT=64100

MODEL_PROVIDER="openai-compatible"
MODEL_BASE_URL="https://api.openai.com/v1"
MODEL_API_KEY="your-api-key"
MODEL_NAME="gpt-4.1-mini"

MEMORY_EXTRACTION_MODEL_NAME="gpt-4.1-mini"

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=""
TELEGRAM_MODE="polling"
TELEGRAM_PROXY=""

# Weixin (via OpenClaw bridge)
WEIXIN_ENABLED=false
WEIXIN_BRIDGE_SECRET=""

# Web
WEB_ORIGIN="http://localhost:64111"

# Security
OWNER_USER_IDS="telegram:123456"
MAX_MESSAGE_LENGTH=4000

# Embedding (SiliconFlow Qwen/Qwen3-Embedding-4B)
EMBEDDING_BASE_URL="https://api.siliconflow.cn/v1"
EMBEDDING_API_KEY=""
EMBEDDING_MODEL="Qwen/Qwen3-Embedding-4B"
EMBEDDING_DIMENSIONS=1024

# Memory retrieval (v0.4)
MEMORY_RETRIEVAL_ENABLED=false
MEMORY_SEMANTIC_TOP_K=30
MEMORY_FINAL_TOP_K=8
MEMORY_MAX_TOTAL_CHARS=1200
MEMORY_VECTOR_INDEX_PROVIDER="pgvector"

# Tools & Actions (v0.5)
TOOLS_ENABLED=false
TOOLS_AUTO_EXECUTE_LOW_RISK=true
TOOLS_ALLOW_MEDIUM_RISK=false
TOOLS_ALLOW_HIGH_RISK=false
DRAFTS_ENABLED=true
TOOL_MAX_CALLS_PER_MESSAGE=3
TOOL_TIMEOUT_MS=10000
TOOL_LOG_INPUT_OUTPUT=true
MCP_ENABLED=false

# Reflection Agent (v0.7)
REFLECTION_ENABLED=true
REFLECTION_OWNER_ONLY=true
REFLECTION_DEFAULT_MESSAGE_LIMIT=80
REFLECTION_MAX_MESSAGE_LIMIT=200
REFLECTION_MIN_MESSAGES=10
REFLECTION_INCLUDE_MEMORIES=true
REFLECTION_AUTO_APPLY=false
REFLECTION_ALLOW_MEMORY_CREATE_PROPOSALS=true
REFLECTION_ALLOW_MEMORY_UPDATE_PROPOSALS=true
REFLECTION_ALLOW_MEMORY_SUPERSEDE_PROPOSALS=true
REFLECTION_PROPOSAL_MIN_CONFIDENCE=0.7
REFLECTION_PROPOSAL_MAX_PER_RUN=20
REFLECTION_ENABLE_GROWTH_LOG=true
