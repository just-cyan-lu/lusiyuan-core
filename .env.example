SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
SILICONFLOW_API_KEY=""
SILICONFLOW_MODEL="Qwen/Qwen2.5-72B-Instruct"

# Embedding connection and vector shape.
EMBEDDING_BASE_URL="https://api.siliconflow.cn/v1"
EMBEDDING_API_KEY=""
