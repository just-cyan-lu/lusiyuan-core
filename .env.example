DATABASE_URL="postgresql://lusiyuan:password@localhost:5432/lusiyuan_core"
PORT=64100

# ─── LLM 多提供商配置 ────────────────────────────────────────────────────────
# ACTIVE_MODEL_PROVIDER 指定当前使用的提供商，值为下方各提供商配置的前缀
# 例如：ACTIVE_MODEL_PROVIDER=openai 会读取 OPENAI_BASE_URL, OPENAI_API_KEY, OPENAI_MODEL
# 支持：openai, anthropic, glm, qwen, deepseek, minimax
ACTIVE_MODEL_PROVIDER="openai"

# OpenAI
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Anthropic (Claude)
ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# GLM (智谱)
GLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
GLM_API_KEY=""
GLM_MODEL="glm-4-plus"

# Qwen (通义千问)
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_API_KEY=""
QWEN_MODEL="qwen-plus"

# DeepSeek
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"

# MiniMax（不支持 vision，图片消息会自动过滤）
MINIMAX_BASE_URL="https://api.minimax.chat/v1"
MINIMAX_API_KEY=""
MINIMAX_MODEL="abab6.5s-chat"
# ─────────────────────────────────────────────────────────────────────────────

# Telegram
# Set TELEGRAM_ENABLED=true to start Telegram bot within the main server process (pnpm dev)
# No need to run a separate pnpm telegram:dev process
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=""
TELEGRAM_MODE="polling"
TELEGRAM_PROXY=""

# Weixin (via OpenClaw bridge)
WEIXIN_ENABLED=false
WEIXIN_BRIDGE_SECRET=""

# Web
WEB_ORIGIN="http://localhost:64111"

# Security
OWNER_USER_IDS="telegram:123456"
MAX_MESSAGE_LENGTH=4000

# Embedding (SiliconFlow Qwen/Qwen3-Embedding-4B)
EMBEDDING_BASE_URL="https://api.siliconflow.cn/v1"
EMBEDDING_API_KEY=""
EMBEDDING_MODEL="Qwen/Qwen3-Embedding-4B"
EMBEDDING_DIMENSIONS=1024

# Memory retrieval (v0.4)
MEMORY_RETRIEVAL_ENABLED=false
MEMORY_SEMANTIC_TOP_K=30
MEMORY_FINAL_TOP_K=8
MEMORY_MAX_TOTAL_CHARS=1200
MEMORY_VECTOR_INDEX_PROVIDER="pgvector"

# Tools & Actions (v0.5)
TOOLS_ENABLED=false
TOOLS_AUTO_EXECUTE_LOW_RISK=true
TOOLS_ALLOW_MEDIUM_RISK=false
TOOLS_ALLOW_HIGH_RISK=false
DRAFTS_ENABLED=true
TOOL_MAX_CALLS_PER_MESSAGE=3
TOOL_TIMEOUT_MS=10000
TOOL_LOG_INPUT_OUTPUT=true
MCP_ENABLED=false

# Reflection Agent (v0.7)
REFLECTION_ENABLED=true
REFLECTION_OWNER_ONLY=true
REFLECTION_DEFAULT_MESSAGE_LIMIT=80
REFLECTION_MAX_MESSAGE_LIMIT=200
REFLECTION_MIN_MESSAGES=10
REFLECTION_INCLUDE_MEMORIES=true
REFLECTION_AUTO_APPLY=false
REFLECTION_PROPOSAL_MIN_CONFIDENCE=0.7
REFLECTION_PROPOSAL_MAX_PER_RUN=20
REFLECTION_ENABLE_GROWTH_LOG=true

# Dream Cycle (v0.75)
DREAM_ENABLED=true
DREAM_AUTO_RUN=false
DREAM_CRON="30 3 * * *"
DREAM_TIMEZONE="Asia/Taipei"

DREAM_DEFAULT_LOOKBACK_HOURS=24
DREAM_MAX_LOOKBACK_DAYS=7
DREAM_MIN_SOURCE_EVENTS=5

DREAM_MAX_MESSAGES=120
DREAM_MAX_TOOL_CALLS=50
DREAM_MAX_DRAFTS=30
DREAM_MAX_REFLECTION_REPORTS=10
DREAM_MAX_MEMORY_PROPOSALS=30

DREAM_LIGHT_ENABLED=true
DREAM_REM_ENABLED=true
DREAM_DEEP_ENABLED=true
DREAM_DIARY_ENABLED=true
DREAM_MORNING_BRIEF_ENABLED=true

DREAM_AUTO_APPLY=false
DREAM_ALLOW_MEMORY_PROPOSALS=true
DREAM_ALLOW_GROWTH_LOG_PROPOSALS=true

DREAM_MIN_SIGNAL_SCORE=0.72
DREAM_MIN_CONFIDENCE=0.70
DREAM_MIN_EVIDENCE_COUNT=2
DREAM_MAX_PROPOSALS_PER_RUN=10

DREAM_DIARY_MAX_CHARS=1200
DREAM_DIARY_VISIBILITY="owner_only"

DREAM_REDACT_PRIVATE_DATA=true
DREAM_LOCK_TTL_MINUTES=60

# Tavily web search (v0.8.1)
TAVILY_ENABLED=false
TAVILY_API_KEY=""
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH="basic"

# Jina AI Reader (v0.8.1)
JINA_ENABLED=true
JINA_API_KEY=""

# Playwright headless browser (v0.8.1)
PLAYWRIGHT_ENABLED=false
PLAYWRIGHT_MAX_PAGE_TEXT_CHARS=12000
PLAYWRIGHT_SCREENSHOT_ENABLED=false

# CDP Browser — connect to user's Chrome (v0.8.1)
CDP_BROWSER_ENABLED=false
CDP_BROWSER_PORT=9222

# External Inbox (v0.8.1)
EXTERNAL_INBOX_ENABLED=false
EXTERNAL_INBOX_AUTO_SUMMARIZE=true
EXTERNAL_INBOX_AUTO_CREATE_DRAFT=true
EXTERNAL_INBOX_MAX_ITEMS_PER_SYNC=50
