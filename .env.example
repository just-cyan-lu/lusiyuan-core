# Bootstrap: required before database-backed live settings can load.
DATABASE_URL="postgresql://lusiyuan:password@localhost:5432/lusiyuan_core"
PORT=64100
WEB_ORIGIN="http://localhost:64111"

# Admin and owner security. These values never move into the database.
ADMIN_API_TOKEN=""
ADMIN_DATABASE_CLEAR_PASSWORD="lusiyuan2026"
OWNER_USER_IDS="telegram:123456"
WEBCHAT_OWNER_USER_ID="web:owner"
WEBCHAT_CODEX_USER_ID="web:codex"

# Model connection profiles. Select the active profile from Admin live settings.
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

GLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
GLM_API_KEY=""
GLM_MODEL="glm-4-plus"

QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_API_KEY=""
QWEN_MODEL="qwen-plus"

DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"

MINIMAX_BASE_URL="https://api.minimaxi.com/v1"
MINIMAX_API_KEY=""
MINIMAX_MODEL="MiniMax-M3"

KIMI_BASE_URL="https://api.moonshot.cn/v1"
KIMI_API_KEY=""
