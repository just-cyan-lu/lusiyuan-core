// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// External identity for a person talking to Lusiyuan.
model User {
  id          String   @id @default(cuid())
  externalId  String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversations             Conversation[]
  identityLink              IdentityLink?
  relationshipEvents        RelationshipStateEvent[]
  identityProposalsMade     IdentityLinkProposal[]   @relation("IdentityProposalSourceUser")
  identityProposalsTargeted IdentityLinkProposal[]   @relation("IdentityProposalTargetUser")
  identityAliases           IdentityAlias[]
  identityBindingCodesIssued   IdentityBindingCode[] @relation("IdentityBindingCodeIssuer")
  identityBindingCodesRedeemed IdentityBindingCode[] @relation("IdentityBindingCodeRedeemer")

  @@map("app_users")
}

/// Chat session context for one user on one channel.
model Conversation {
  id                     String   @id @default(cuid())
  userId                 String
  channel                String
  externalConversationId String
  metadata               Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user             User                         @relation(fields: [userId], references: [id])
  messages         Message[]
  contextSummaries ConversationContextSummary[]

  @@index([userId])
  @@index([channel])
  @@index([externalConversationId])
  @@map("chat_conversations")
}

/// Stored user, assistant, tool, and intermediate chat messages.
model Message {
  id                String   @id @default(cuid())
  conversationId    String
  role              String
  content           String
  externalMessageId String?
  isIntermediate    Boolean  @default(false)
  metadata          Json?
  createdAt         DateTime @default(now())

  conversation Conversation       @relation(fields: [conversationId], references: [id])
  embeddings   MessageEmbedding[]
  voiceCaches  VoiceAudioCache[]

  @@unique([conversationId, externalMessageId])
  @@index([conversationId])
  @@index([createdAt])
  @@index([externalMessageId])
  @@map("chat_messages")
}

/// Cached generated audio for assistant messages.
model VoiceAudioCache {
  id               String   @id @default(cuid())
  messageId        String
  cacheKey         String   @unique
  textHash         String
  voiceProfileHash String
  provider         String
  model            String
  voiceId          String
  format           String
  mimeType         String
  sampleRate       Int
  bitrate          Int
  channel          Int
  storageKind      String   @default("file")
  storagePath      String
  byteSize         Int
  durationMs       Int?
  status           String   @default("ready")
  providerTraceId  String?
  lastPlayedAt     DateTime
  playCount        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([lastPlayedAt])
  @@index([createdAt])
  @@map("voice_audio_caches")
}

/// Compact summaries of older conversation ranges used as chat context.
model ConversationContextSummary {
  id             String   @id @default(cuid())
  conversationId String
  fromMessageId  String
  toMessageId    String
  fromCreatedAt  DateTime
  toCreatedAt    DateTime
  messageCount   Int
  summary        String
  status         String   @default("active")
  source         String   @default("auto_compact")
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, toMessageId])
  @@index([conversationId, status, toCreatedAt])
  @@index([toCreatedAt])
  @@map("conversation_context_summaries")
}

/// Raw inbound events received from external channels.
model ChannelEvent {
  id                String   @id @default(cuid())
  channel           String
  externalEventId   String?
  externalUserId    String?
  externalMessageId String?
  payload           Json
  status            String   @default("received")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([channel])
  @@index([externalEventId])
  @@index([externalMessageId])
  @@map("channel_events")
}

/// Long-term memories used to personalize future replies.
model Memory {
  id               String    @id @default(cuid())
  personId         String?
  type             String
  scope            String    @default("person")
  tier             String    @default("temp")
  tierMentionCount Int       @default(0)
  tierEnteredAt    DateTime?
  content          String
  summary          String?
  status           String    @default("active")
  sourceMessageIds Json?
  mentionDayKeys   Json?
  lastMentionedAt  DateTime?
  lastAccessedAt   DateTime?
  accessCount      Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  person     PersonIdentity?   @relation(fields: [personId], references: [id], onDelete: Cascade)
  embeddings MemoryEmbedding[]

  @@index([personId])
  @@index([type])
  @@index([tier])
  @@index([status, scope, type])
  @@index([personId, status])
  @@index([scope, status, tier])
  @@index([lastMentionedAt])
  @@map("memories")
}

/// Audit trail for tool calls made by the assistant.
model ToolCallLog {
  id             String   @id @default(cuid())
  toolName       String
  riskLevel      String
  status         String
  userId         String?
  conversationId String?
  messageId      String?
  channel        String?
  input          Json?
  output         Json?
  error          String?
  blocked        Boolean  @default(false)
  blockReason    String?
  durationMs     Int?
  createdAt      DateTime @default(now())

  @@index([toolName])
  @@index([userId])
  @@index([conversationId])
  @@index([status])
  @@index([createdAt])
  @@map("tool_call_logs")
}

/// Admin-editable configuration for reusable skills.
model SkillConfig {
  id        String   @id @default(cuid())
  skillId   String   @unique
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("skill_configs")
}

/// Live, non-secret application settings changed from Admin.
model SystemSetting {
  key       String   @id
  value     Json
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
  @@map("system_settings")
}

/// Audit trail for live setting changes.
model SystemSettingEvent {
  id        String   @id @default(cuid())
  key       String
  oldValue  Json?
  newValue  Json
  changedBy String?
  source    String   @default("admin")
  createdAt DateTime @default(now())

  @@index([key])
  @@index([createdAt])
  @@map("system_setting_events")
}

/// Xiaohongshu post tracked by the admin workbench.
model XiaohongshuPost {
  id           String    @id @default(cuid())
  externalId   String?   @unique
  url          String?
  title        String
  caption      String?
  authorName   String?
  postType     String    @default("daily")
  imageCount   Int       @default(0)
  imageAlts    Json?
  status       String    @default("active")
  source       String    @default("manual")
  publishedAt  DateTime?
  lastSyncedAt DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  comments XiaohongshuComment[]

  @@index([status])
  @@index([postType])
  @@index([createdAt])
  @@map("xiaohongshu_posts")
}

/// Xiaohongshu comment tracked for manual reply drafting.
model XiaohongshuComment {
  id                  String    @id @default(cuid())
  postId              String
  parentId            String?
  replyToId           String?
  externalId          String?
  authorName          String?
  authorUserId        String?
  content             String
  isAuthor            Boolean   @default(false)
  replyToAuthorName   String?
  replyToAuthorUserId String?
  sortOrder           Int       @default(0)
  status              String    @default("pending")
  replyNeed           String    @default("unknown")
  source              String    @default("manual")
  publishedAt         DateTime?
  lastSyncedAt        DateTime?
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  post          XiaohongshuPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent        XiaohongshuComment?     @relation("XiaohongshuThreadReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       XiaohongshuComment[]    @relation("XiaohongshuThreadReplies")
  replyTo       XiaohongshuComment?     @relation("XiaohongshuDirectReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  directReplies XiaohongshuComment[]    @relation("XiaohongshuDirectReplies")
  drafts        XiaohongshuReplyDraft[]

  @@unique([postId, externalId])
  @@index([postId])
  @@index([parentId])
  @@index([replyToId])
  @@index([postId, parentId, sortOrder])
  @@index([isAuthor])
  @@index([status])
  @@index([replyNeed])
  @@index([createdAt])
  @@map("xiaohongshu_comments")
}

/// Draft reply generated for a Xiaohongshu comment.
model XiaohongshuReplyDraft {
  id              String   @id @default(cuid())
  commentId       String
  originalContent String
  content         String
  risk            String
  commentType     String
  awareness       String?
  voice           String?
  boundary        String?
  reason          String?
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  comment XiaohongshuComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([risk])
  @@index([status])
  @@index([createdAt])
  @@map("xiaohongshu_reply_drafts")
}

/// A reusable lesson learned from an owner's final response decision.
model ExpressionLearningExample {
  id              String    @id @default(cuid())
  sourceRef       String    @unique
  sourceType      String
  sourceId        String?
  scene           String
  contextText     String
  draftText       String?
  finalText       String?
  outcome         String
  ownerAction     String
  ownerNote       String?
  lesson          String
  reasoning       String?
  strategy        String?
  tone            String?
  avoidances      Json?
  tags            Json?
  confidence      Float     @default(0.7)
  status          String    @default("active")
  analysisVersion Int       @default(1)
  embeddingStatus String    @default("pending")
  embeddingError  String?
  lastUsedAt      DateTime?
  accessCount     Int       @default(0)
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  embeddings      ExpressionLearningEmbedding[]
  trainingRecords ExpressionLearningTrainingRecord[]

  @@index([scene, status])
  @@index([outcome])
  @@index([ownerAction])
  @@index([createdAt])
  @@map("expression_learning_examples")
}

/// Complete audit record for one expression-learning training interaction.
model ExpressionLearningTrainingRecord {
  id                String   @id @default(cuid())
  sourceType        String
  scene             String
  status            String   @default("started")
  contextText       String?
  draftText         String?
  finalText         String?
  outcome           String?
  ownerAction       String?
  ownerNote         String?
  reasonText        String?
  generatedQuestion Json?
  generatedDraft    Json?
  analysisSnapshot  Json?
  exportPayload     Json?
  rawPayload        Json?
  exampleId         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  example ExpressionLearningExample? @relation(fields: [exampleId], references: [id], onDelete: SetNull)

  @@index([sourceType])
  @@index([scene])
  @@index([status])
  @@index([outcome])
  @@index([exampleId])
  @@index([createdAt])
  @@map("expression_learning_training_records")
}

/// Vector index for expression-learning examples.
model ExpressionLearningEmbedding {
  id          String                       @id @default(cuid())
  exampleId   String
  provider    String
  model       String
  dimensions  Int
  contentHash String
  embedding   Unsupported("vector(1024)")?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  example ExpressionLearningExample @relation(fields: [exampleId], references: [id], onDelete: Cascade)

  @@unique([exampleId, provider, model, dimensions])
  @@index([exampleId])
  @@map("expression_learning_embeddings")
}

/// Current global runtime state for Lusiyuan.
model RuntimeState {
  id                 String   @id @default(cuid())
  key                String   @unique @default("global")
  moodLabel          String   @default("平稳在线")
  energyLevel        Int      @default(62)
  recentEventSummary String?
  statusNote         String?
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  events RuntimeStateEvent[]

  @@map("runtime_states")
}

/// Timeline of runtime state changes.
model RuntimeStateEvent {
  id               String   @id @default(cuid())
  runtimeStateId   String
  eventType        String
  source           String?
  summary          String
  patch            Json?
  before           Json?
  after            Json?
  userId           String?
  conversationId   String?
  sourceMessageIds Json?
  channel          String?
  createdAt        DateTime @default(now())

  runtimeState RuntimeState @relation(fields: [runtimeStateId], references: [id], onDelete: Cascade)

  @@index([runtimeStateId])
  @@index([eventType])
  @@index([source])
  @@index([createdAt])
  @@map("runtime_state_events")
}

/// Things Lusiyuan is actually trying to do when idle.
model AutonomousTask {
  id          String    @id @default(cuid())
  title       String
  description String
  type        String    @default("custom")
  status      String    @default("active")
  priority    Int       @default(50)
  currentStep String?
  nextStep    String?
  createdBy   String    @default("admin")
  lastRunAt   DateTime?
  completedAt DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  runs      AutonomousTaskRun[]
  artifacts AutonomousArtifact[]

  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([lastRunAt])
  @@map("autonomous_tasks")
}

/// One idle/manual step taken on an autonomous task.
model AutonomousTaskRun {
  id         String    @id @default(cuid())
  taskId     String
  trigger    String
  status     String    @default("running")
  summary    String?
  plan       Json?
  result     Json?
  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  task      AutonomousTask       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  artifacts AutonomousArtifact[]

  @@index([taskId])
  @@index([status])
  @@index([trigger])
  @@index([startedAt])
  @@map("autonomous_task_runs")
}

/// Concrete output from an autonomous task, such as a note, draft, or plan.
model AutonomousArtifact {
  id        String   @id @default(cuid())
  taskId    String
  runId     String?
  kind      String   @default("note")
  title     String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task AutonomousTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  run  AutonomousTaskRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([runId])
  @@index([kind])
  @@index([createdAt])
  @@map("autonomous_artifacts")
}

/// Per-user relationship state between Lusiyuan and one person.
model PersonIdentity {
  id        String   @id @default(cuid())
  label     String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identityLinks      IdentityLink[]
  identityAliases    IdentityAlias[]
  relationshipState  RelationshipState?
  relationshipEvents RelationshipStateEvent[]
  identityProposals  IdentityLinkProposal[]
  identityBindingCodes IdentityBindingCode[]
  reviewProposals    RelationshipReviewProposal[]
  reviewEvidences    RelationshipReviewEvidence[]
  memories           Memory[]

  @@index([label])
  @@map("person_identities")
}

/// Link between one channel account and one real-person identity.
model IdentityLink {
  id         String   @id @default(cuid())
  personId   String
  userId     String   @unique
  source     String   @default("auto_singleton")
  verifiedBy String?
  createdAt  DateTime @default(now())

  person PersonIdentity @relation(fields: [personId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([source])
  @@map("identity_links")
}

/// Stable self-claimed names for one real-person identity, independent of mutable channel display names.
model IdentityAlias {
  id              String   @id @default(cuid())
  personId        String
  sourceUserId    String?
  value           String
  normalizedValue String
  source          String   @default("self_identification")
  confidence      Float    @default(0.7)
  mentionCount    Int      @default(1)
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  person     PersonIdentity @relation(fields: [personId], references: [id], onDelete: Cascade)
  sourceUser User?          @relation(fields: [sourceUserId], references: [id], onDelete: SetNull)

  @@unique([personId, normalizedValue])
  @@index([personId])
  @@index([sourceUserId])
  @@index([normalizedValue])
  @@index([lastSeenAt])
  @@map("identity_aliases")
}

/// System suspicion that one channel account may belong to an existing real-person identity.
model IdentityLinkProposal {
  id             String    @id @default(cuid())
  sourceUserId   String
  targetPersonId String
  targetUserId   String?
  reason         String
  evidence       Json?
  confidence     Float     @default(0.65)
  status         String    @default("pending")
  source         String    @default("rules")
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sourceUser   User           @relation("IdentityProposalSourceUser", fields: [sourceUserId], references: [id], onDelete: Cascade)
  targetPerson PersonIdentity @relation(fields: [targetPersonId], references: [id], onDelete: Cascade)
  targetUser   User?          @relation("IdentityProposalTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([sourceUserId])
  @@index([targetPersonId])
  @@index([targetUserId])
  @@index([status])
  @@index([confidence])
  @@index([createdAt])
  @@map("identity_link_proposals")
}

/// Short-lived user-facing code used to verify that two channel accounts belong to one person.
model IdentityBindingCode {
  id             String    @id @default(cuid())
  code           String    @unique
  issuerUserId   String
  issuerPersonId String
  redeemedUserId String?
  status         String    @default("active")
  expiresAt      DateTime
  redeemedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  issuerUser   User           @relation("IdentityBindingCodeIssuer", fields: [issuerUserId], references: [id], onDelete: Cascade)
  issuerPerson PersonIdentity @relation(fields: [issuerPersonId], references: [id], onDelete: Cascade)
  redeemedUser User?          @relation("IdentityBindingCodeRedeemer", fields: [redeemedUserId], references: [id], onDelete: SetNull)

  @@index([issuerUserId])
  @@index([issuerPersonId])
  @@index([redeemedUserId])
  @@index([status])
  @@index([expiresAt])
  @@map("identity_binding_codes")
}

/// Relationship state between Lusiyuan and one real-person identity.
model RelationshipState {
  id                String    @id @default(cuid())
  personId          String    @unique
  relationshipLabel String    @default("刚认识")
  affinity          Int       @default(10)
  userIntroduction  String?
  interactionStyle  String?
  summary           String?
  recentSignal      String?
  statusNote        String?
  metadata          Json?
  lastInteractionAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  person          PersonIdentity               @relation(fields: [personId], references: [id], onDelete: Cascade)
  events          RelationshipStateEvent[]
  reviewProposals RelationshipReviewProposal[]
  reviewEvidences RelationshipReviewEvidence[]

  @@index([personId])
  @@index([updatedAt])
  @@map("relationship_states")
}

/// Timeline of relationship state changes for one real-person identity.
model RelationshipStateEvent {
  id                  String   @id @default(cuid())
  relationshipStateId String
  personId            String
  userId              String?
  eventType           String
  source              String?
  summary             String
  patch               Json?
  before              Json?
  after               Json?
  conversationId      String?
  messageId           String?
  channel             String?
  createdAt           DateTime @default(now())

  relationshipState RelationshipState @relation(fields: [relationshipStateId], references: [id], onDelete: Cascade)
  person            PersonIdentity    @relation(fields: [personId], references: [id], onDelete: Cascade)
  user              User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([relationshipStateId])
  @@index([personId])
  @@index([userId])
  @@index([eventType])
  @@index([source])
  @@index([createdAt])
  @@map("relationship_state_events")
}

/// Dream-generated relationship review for one real-person identity.
model RelationshipReviewProposal {
  id                  String    @id @default(cuid())
  reportId            String?
  relationshipStateId String
  personId            String
  userId              String?
  conversationId      String?
  channel             String?
  source              String    @default("dream")
  status              String    @default("pending")
  reason              String
  confidence          Float     @default(0.7)
  evidenceCount       Int       @default(0)
  beforeSnapshot      Json?
  proposedPatch       Json?
  afterSnapshot       Json?
  appliedAt           DateTime?
  reviewedBy          String?
  reviewedAt          DateTime?
  rawOutput           Json?
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  report            DreamConsolidationReport?    @relation(fields: [reportId], references: [id], onDelete: SetNull)
  relationshipState RelationshipState            @relation(fields: [relationshipStateId], references: [id], onDelete: Cascade)
  person            PersonIdentity               @relation(fields: [personId], references: [id], onDelete: Cascade)
  evidences         RelationshipReviewEvidence[]

  @@index([reportId])
  @@index([relationshipStateId])
  @@index([personId])
  @@index([userId])
  @@index([conversationId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@map("relationship_review_proposals")
}

/// Single evidence item used by a relationship review.
model RelationshipReviewEvidence {
  id                  String   @id @default(cuid())
  proposalId          String
  relationshipStateId String
  personId            String
  userId              String?
  conversationId      String?
  messageId           String?
  channel             String?
  source              String   @default("dream")
  evidenceKey         String
  evidenceType        String
  polarity            String   @default("neutral")
  confidence          Float    @default(0.7)
  content             String
  reason              String
  affectsFields       Json?
  sourceMessageIds    Json?
  metadata            Json?
  createdAt           DateTime @default(now())

  proposal          RelationshipReviewProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  relationshipState RelationshipState          @relation(fields: [relationshipStateId], references: [id], onDelete: Cascade)
  person            PersonIdentity             @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([relationshipStateId, evidenceKey])
  @@index([proposalId])
  @@index([relationshipStateId])
  @@index([personId])
  @@index([userId])
  @@index([conversationId])
  @@index([messageId])
  @@index([evidenceType])
  @@index([polarity])
  @@index([createdAt])
  @@map("relationship_review_evidence")
}

/// Vector embeddings attached to long-term memories.
model MemoryEmbedding {
  id          String                       @id @default(cuid())
  memoryId    String
  provider    String
  model       String
  dimensions  Int
  contentHash String
  embedding   Unsupported("vector(1024)")?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@unique([memoryId, provider, model, dimensions])
  @@index([memoryId])
  @@map("memory_embeddings")
}

/// Vector embeddings attached to raw chat messages for old-dialogue recall.
model MessageEmbedding {
  id             String                       @id @default(cuid())
  messageId      String
  conversationId String
  provider       String
  model          String
  dimensions     Int
  contentHash    String
  embedding      Unsupported("vector(1024)")?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, provider, model, dimensions])
  @@index([messageId])
  @@index([conversationId])
  @@map("message_embeddings")
}

// ── Dream learning outputs ───────────────────────────────────────────────────

/// Risk items detected by dream consolidation.
model MemoryRiskFlag {
  id                String   @id @default(cuid())
  reportId          String
  type              String
  severity          String
  description       String
  suggestedAction   String?
  relatedMessageIds Json?
  status            String   @default("open")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  report DreamConsolidationReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([type])
  @@index([severity])
  @@index([status])
  @@map("memory_risk_flags")
}

/// Proposed growth-log style entries generated from dream consolidation.
model GrowthLogProposal {
  id               String   @id @default(cuid())
  reportId         String
  title            String
  content          String
  tags             Json?
  confidence       Float
  status           String   @default("pending")
  sourceMessageIds Json?
  appliedMemoryId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  report DreamConsolidationReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([status])
  @@index([createdAt])
  @@map("growth_log_proposals")
}

// ─── v0.75 Dream Cycle ────────────────────────────────────────────────────────

/// Dream cycle task that summarizes, extracts signals, and consolidates insights.
model DreamJob {
  id             String    @id @default(cuid())
  status         String    @default("pending")
  triggerType    String
  scope          String
  userId         String?
  conversationId String?
  channel        String?
  fromTime       DateTime?
  toTime         DateTime?
  phase          String?
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  metadata       Json?

  dailyNotes   DailyNote[]
  signals      DreamSignal[]
  diaryEntries DreamDiaryEntry[]
  reports      DreamConsolidationReport[]

  @@index([status])
  @@index([triggerType])
  @@index([scope])
  @@index([createdAt])
  @@map("dream_jobs")
}

/// Daily summary note generated by the dream cycle.
model DailyNote {
  id          String   @id @default(cuid())
  jobId       String?
  date        DateTime
  scope       String
  userId      String?
  channel     String?
  title       String?
  summary     String
  keyPoints   Json?
  sourceStats Json?
  riskSummary Json?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job DreamJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([scope])
  @@index([userId])
  @@index([status])
  @@map("dream_daily_notes")
}

/// Signal extracted from messages, memories, tools, or dream context.
model DreamSignal {
  id            String   @id @default(cuid())
  jobId         String?
  signalType    String
  content       String
  summary       String?
  confidence    Float
  strength      Float
  riskLevel     String   @default("low")
  sourceTypes   Json?
  sourceIds     Json?
  evidenceCount Int      @default(0)
  tags          Json?
  entities      Json?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  job DreamJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([signalType])
  @@index([confidence])
  @@index([strength])
  @@index([riskLevel])
  @@index([status])
  @@map("dream_signals")
}

/// Inner-diary style entry generated from dream signals.
model DreamDiaryEntry {
  id               String   @id @default(cuid())
  jobId            String?
  date             DateTime
  title            String?
  content          String
  style            String   @default("lusiyuan_inner_diary")
  grounded         Boolean  @default(true)
  sourceSignalIds  Json?
  sourceMessageIds Json?
  visibility       String   @default("owner_only")
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  job DreamJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([visibility])
  @@index([status])
  @@map("dream_diary_entries")
}

/// Report for dream-cycle consolidation and generated proposals.
model DreamConsolidationReport {
  id             String   @id @default(cuid())
  jobId          String?
  summary        String
  phase          String
  candidateCount Int      @default(0)
  promotedCount  Int      @default(0)
  rejectedCount  Int      @default(0)
  riskCount      Int      @default(0)
  rawOutput      Json?
  metadata       Json?
  createdAt      DateTime @default(now())

  job                         DreamJob?                    @relation(fields: [jobId], references: [id], onDelete: SetNull)
  riskFlags                   MemoryRiskFlag[]
  growthLogs                  GrowthLogProposal[]
  relationshipReviewProposals RelationshipReviewProposal[]

  @@index([phase])
  @@index([createdAt])
  @@map("dream_consolidation_reports")
}

/// Runtime lock that prevents overlapping dream jobs.
model DreamLock {
  id        String   @id @default(cuid())
  lockKey   String   @unique
  owner     String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("dream_locks")
}

/// Snapshot of an external page read by Jina, Playwright, or Chrome DevTools MCP.
model ExternalPageSnapshot {
  id             String   @id @default(cuid())
  url            String
  tool           String // jina | playwright | chrome-devtools-mcp
  content        String
  screenshotPath String?
  createdAt      DateTime @default(now())

  @@index([url])
  @@index([tool])
  @@index([createdAt])
  @@map("external_page_snapshots")
}
